// AgencyOS — SQLite-compatible Database Schema
// Covers all 10 modules: CRM, Onboarding, Projects, Analytics,
// Social, Email, SEO, Ads, Billing, Client Portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CORE: USERS & ORGANIZATIONS
// ─────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           OrganizationUser[]
  clients         Client[]
  leads           Lead[]
  contacts        Contact[]
  accounts        Account[]
  deals           Deal[]
  meetings        Meeting[]
  callLogs        CallLog[]
  products        Product[]
  quotes          Quote[]
  cases           Case[]
  crmDocuments    CrmDocument[]
  projects        Project[]
  invoices        Invoice[]
  socialAccounts  SocialAccount[]
  emailCampaigns  EmailCampaign[]
  seoProjects     SeoProject[]
  adAccounts      AdAccount[]
  reportTemplates ReportTemplate[]
  tags            Tag[]
  webhooks        Webhook[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  avatar       String?
  passwordHash String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organizations OrganizationUser[]
  assignedTasks Task[]             @relation("TaskAssignee")
  createdTasks  Task[]             @relation("TaskCreator")
  comments      Comment[]
  notifications Notification[]
  timeEntries   TimeEntry[]
  sessions      Session[]
  auditLogs     AuditLog[]
}

model OrganizationUser {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("SPECIALIST")
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 1: CRM & LEAD MANAGEMENT
// ─────────────────────────────────────────

model Lead {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String
  phone          String?
  company        String?
  website        String?
  status         String    @default("NEW")
  source         String    @default("OTHER")
  score          Int       @default(0)
  estimatedValue Float?
  notes          String?
  assignedToId   String?
  nextFollowUpAt DateTime?
  wonAt          DateTime?
  lostAt         DateTime?
  lostReason     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities   LeadActivity[]
  client       Client?
  tags         TagOnLead[]
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  title     String
  body      String?
  createdAt DateTime @default(now())
  createdBy String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 2: CLIENTS & ONBOARDING
// ─────────────────────────────────────────

model Client {
  id             String    @id @default(cuid())
  organizationId String
  leadId         String?   @unique
  name           String
  email          String
  phone          String?
  company        String
  website        String?
  industry       String?
  logo           String?
  timezone       String    @default("UTC")
  isActive       Boolean   @default(true)
  portalPassword String?
  contractValue  Float?
  billingCycle   String    @default("MONTHLY")
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead?               @relation(fields: [leadId], references: [id])
  onboarding     Onboarding?
  projects       Project[]
  invoices       Invoice[]
  assets         ClientAsset[]
  credentials    ClientCredential[]
  tags           TagOnClient[]
  portalSessions ClientPortalSession[]
  approvals      Approval[]
  analytics      AnalyticsIntegration[]
}

model Onboarding {
  id          String    @id @default(cuid())
  clientId    String    @unique
  status      String    @default("PENDING")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  checklist OnboardingItem[]
  responses QuestionnaireResponse[]
}

model OnboardingItem {
  id           String    @id @default(cuid())
  onboardingId String
  title        String
  description  String?
  isRequired   Boolean   @default(true)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  order        Int       @default(0)

  onboarding Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
}

model QuestionnaireResponse {
  id           String    @id @default(cuid())
  onboardingId String
  question     String
  answer       String?
  answeredAt   DateTime?

  onboarding Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
}

model ClientAsset {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  type       String
  url        String
  mimeType   String?
  sizeBytes  Int?
  uploadedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientCredential {
  id              String   @id @default(cuid())
  clientId        String
  platform        String
  label           String
  username        String?
  encryptedSecret String?
  notes           String?
  createdAt       DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientPortalSession {
  id        String   @id @default(cuid())
  clientId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 3: PROJECT MANAGEMENT
// ─────────────────────────────────────────

model Project {
  id             String    @id @default(cuid())
  organizationId String
  clientId       String
  name           String
  description    String?
  status         String    @default("ACTIVE")
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  tasks        Task[]
  milestones   Milestone[]
  tags         TagOnProject[]
}

model Task {
  id           String    @id @default(cuid())
  projectId    String
  parentId     String?
  title        String
  description  String?
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  assigneeId   String?
  creatorId    String
  dueDate      DateTime?
  estimatedHrs Float?
  order        Int       @default(0)
  isQaRequired Boolean   @default(false)
  qaApprovedAt DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Task?          @relation("SubTasks", fields: [parentId], references: [id])
  subtasks    Task[]         @relation("SubTasks")
  assignee    User?          @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User           @relation("TaskCreator", fields: [creatorId], references: [id])
  comments    Comment[]
  timeEntries TimeEntry[]
  attachments TaskAttachment[]
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String
  description String?
  startedAt   DateTime
  stoppedAt   DateTime?
  durationMin Int?
  createdAt   DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  name       String
  url        String
  mimeType   String?
  uploadedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 4: ANALYTICS & REPORTING
// ─────────────────────────────────────────

model AnalyticsIntegration {
  id           String    @id @default(cuid())
  clientId     String
  platform     String
  accountId    String
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  snapshots MetricSnapshot[]

  @@unique([clientId, platform, accountId])
  @@index([clientId])
}

model MetricSnapshot {
  id            String   @id @default(cuid())
  integrationId String
  date          DateTime
  metric        String
  value         Float
  dimensions    String?
  createdAt     DateTime @default(now())

  integration AnalyticsIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, date, metric])
  @@index([integrationId, date])
}

model Report {
  id             String    @id @default(cuid())
  organizationId String
  clientId       String
  templateId     String?
  title          String
  period         String
  startDate      DateTime
  endDate        DateTime
  data           String    @default("{}")
  pdfUrl         String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  template ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([clientId, startDate])
}

model ReportTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  config         String   @default("{}")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reports      Report[]
}

model Alert {
  id          String    @id @default(cuid())
  clientId    String
  metric      String
  condition   String
  threshold   Float
  severity    String    @default("WARNING")
  message     String?
  triggeredAt DateTime?
  resolvedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([clientId])
}

// ─────────────────────────────────────────
// MODULE 5: SOCIAL MEDIA SCHEDULING
// ─────────────────────────────────────────

model SocialAccount {
  id             String    @id @default(cuid())
  organizationId String
  clientId       String?
  platform       String
  accountId      String
  accountName    String
  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts        SocialPost[]

  @@unique([organizationId, platform, accountId])
}

model SocialPost {
  id              String    @id @default(cuid())
  socialAccountId String
  caption         String?
  mediaUrls       String    @default("[]")
  hashtags        String    @default("[]")
  status          String    @default("DRAFT")
  scheduledAt     DateTime?
  publishedAt     DateTime?
  failureReason   String?
  approvalId      String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  socialAccount SocialAccount     @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  approval      Approval?         @relation(fields: [approvalId], references: [id])
  metrics       SocialPostMetric[]

  @@index([socialAccountId, scheduledAt])
}

model SocialPostMetric {
  id          String   @id @default(cuid())
  postId      String
  fetchedAt   DateTime @default(now())
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  saves       Int      @default(0)

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 6: EMAIL MARKETING AUTOMATION
// ─────────────────────────────────────────

model EmailList {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  name           String
  description    String?
  createdAt      DateTime @default(now())

  subscribers EmailSubscriber[]
  segments    EmailSegment[]
  campaigns   EmailCampaign[]
}

model EmailSubscriber {
  id             String    @id @default(cuid())
  listId         String
  email          String
  firstName      String?
  lastName       String?
  tags           String    @default("[]")
  metadata       String?
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  list  EmailList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  sends EmailSend[]

  @@unique([listId, email])
}

model EmailSegment {
  id        String   @id @default(cuid())
  listId    String
  name      String
  rules     String   @default("[]")
  createdAt DateTime @default(now())

  list      EmailList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  campaigns EmailCampaign[]
}

model EmailCampaign {
  id                String    @id @default(cuid())
  organizationId    String
  listId            String
  segmentId         String?
  name              String
  subject           String
  previewText       String?
  htmlBody          String
  textBody          String?
  status            String    @default("DRAFT")
  scheduledAt       DateTime?
  sentAt            DateTime?
  totalSent         Int       @default(0)
  totalOpened       Int       @default(0)
  totalClicked      Int       @default(0)
  totalBounced      Int       @default(0)
  totalUnsubscribed Int       @default(0)
  abVariant         String?
  abTestParentId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  list         EmailList      @relation(fields: [listId], references: [id])
  segment      EmailSegment?  @relation(fields: [segmentId], references: [id])
  sends        EmailSend[]
  sequences    EmailSequence[]
}

model EmailSequence {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  delayDays  Int      @default(0)
  delayHours Int      @default(0)
  subject    String
  htmlBody   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model EmailSend {
  id             String    @id @default(cuid())
  campaignId     String
  subscriberId   String
  sentAt         DateTime  @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?
  messageId      String?

  campaign   EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber EmailSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([campaignId, subscriberId])
}

// ─────────────────────────────────────────
// MODULE 7: SEO TRACKING
// ─────────────────────────────────────────

model SeoProject {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String
  domain         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  keywords     SeoKeyword[]
  backlinks    Backlink[]
  audits       SeoAudit[]

  @@unique([organizationId, clientId, domain])
}

model SeoKeyword {
  id           String   @id @default(cuid())
  seoProjectId String
  keyword      String
  targetUrl    String?
  country      String   @default("US")
  language     String   @default("en")
  createdAt    DateTime @default(now())

  seoProject SeoProject       @relation(fields: [seoProjectId], references: [id], onDelete: Cascade)
  rankings   KeywordRanking[]

  @@unique([seoProjectId, keyword, country])
}

model KeywordRanking {
  id           String   @id @default(cuid())
  keywordId    String
  position     Int?
  url          String?
  searchVolume Int?
  date         DateTime
  createdAt    DateTime @default(now())

  keyword SeoKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date])
  @@index([keywordId, date])
}

model Backlink {
  id           String    @id @default(cuid())
  seoProjectId String
  sourceUrl    String
  targetUrl    String
  anchorText   String?
  doFollow     Boolean   @default(true)
  domainRating Float?
  firstSeenAt  DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  isLost       Boolean   @default(false)
  lostAt       DateTime?

  seoProject SeoProject @relation(fields: [seoProjectId], references: [id], onDelete: Cascade)

  @@unique([seoProjectId, sourceUrl, targetUrl])
}

model SeoAudit {
  id           String   @id @default(cuid())
  seoProjectId String
  score        Int?
  issues       String   @default("[]")
  pagesScanned Int      @default(0)
  auditedAt    DateTime @default(now())

  seoProject SeoProject @relation(fields: [seoProjectId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 8: PAID ADS MANAGEMENT
// ─────────────────────────────────────────

model AdAccount {
  id             String    @id @default(cuid())
  organizationId String
  clientId       String
  platform       String
  accountId      String
  accountName    String
  currency       String    @default("USD")
  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    AdCampaign[]

  @@unique([organizationId, platform, accountId])
}

model AdCampaign {
  id          String    @id @default(cuid())
  adAccountId String
  externalId  String
  name        String
  status      String    @default("active")
  objective   String?
  dailyBudget Float?
  totalBudget Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adAccount AdAccount  @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  metrics   AdMetric[]
  rules     AdRule[]
  adSets    AdSet[]

  @@unique([adAccountId, externalId])
}

model AdSet {
  id          String  @id @default(cuid())
  campaignId  String
  externalId  String
  name        String
  status      String
  dailyBudget Float?
  targeting   String?

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads      Ad[]
}

model Ad {
  id             String  @id @default(cuid())
  adSetId        String
  externalId     String
  name           String
  status         String
  headline       String?
  description    String?
  mediaUrl       String?
  destinationUrl String?

  adSet AdSet @relation(fields: [adSetId], references: [id], onDelete: Cascade)
}

model AdMetric {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  reach       Int      @default(0)
  ctr         Float?
  cpc         Float?
  cpm         Float?
  roas        Float?
  cpa         Float?
  createdAt   DateTime @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date])
}

model AdRule {
  id         String    @id @default(cuid())
  campaignId String
  name       String
  metric     String
  condition  String
  threshold  Float
  action     String
  adjustment Float?
  isActive   Boolean   @default(true)
  lastRanAt  DateTime?
  createdAt  DateTime  @default(now())

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MODULE 9: CLIENT APPROVAL PORTAL
// ─────────────────────────────────────────

model Approval {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  description String?
  type        String
  fileUrl     String?
  status      String    @default("PENDING")
  feedback    String?
  reviewedAt  DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  socialPost SocialPost?
}

// ─────────────────────────────────────────
// MODULE 10: BILLING & FINANCE
// ─────────────────────────────────────────

model Invoice {
  id                    String    @id @default(cuid())
  organizationId        String
  clientId              String
  number                String    @unique
  status                String    @default("DRAFT")
  currency              String    @default("USD")
  subtotal              Float
  tax                   Float     @default(0)
  total                 Float
  dueDate               DateTime
  paidAt                DateTime?
  notes                 String?
  stripePaymentIntentId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client            @relation(fields: [clientId], references: [id])
  lineItems    InvoiceLineItem[]
  payments     Payment[]
}

model InvoiceLineItem {
  id          String @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String
  reference String?
  paidAt    DateTime @default(now())
  notes     String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id            String    @id @default(cuid())
  clientId      String    @unique
  planName      String
  amount        Float
  billingCycle  String    @default("MONTHLY")
  nextBillingAt DateTime?
  stripeSubId   String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

// ─────────────────────────────────────────
// SHARED: TAGS, NOTIFICATIONS, AUDIT LOG
// ─────────────────────────────────────────

model Tag {
  id             String @id @default(cuid())
  organizationId String
  name           String
  color          String @default("#6366f1")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        TagOnLead[]
  clients      TagOnClient[]
  projects     TagOnProject[]

  @@unique([organizationId, name])
}

model TagOnLead {
  tagId  String
  leadId String

  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([tagId, leadId])
}

model TagOnClient {
  tagId    String
  clientId String

  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([tagId, clientId])
}

model TagOnProject {
  tagId     String
  projectId String

  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([tagId, projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    String?
  after     String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
}

model Webhook {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  events         String   @default("[]")
  secret         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CRM PHASE 1: CONTACTS, ACCOUNTS, DEALS
// ─────────────────────────────────────────

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  accountId      String?
  leadId         String?
  firstName      String
  lastName       String
  email          String
  phone          String?
  title          String?
  department     String?
  source         String   @default("OTHER")
  assignedToId   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account      Account?          @relation(fields: [accountId], references: [id])
  deals        DealContact[]
  meetings     MeetingContact[]
  calls        CallLog[]
  quotes       Quote[]
  activities   ContactActivity[]
}

model ContactActivity {
  id        String   @id @default(cuid())
  contactId String
  type      String
  title     String
  body      String?
  createdAt DateTime @default(now())
  createdBy String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Account {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  website        String?
  industry       String?
  phone          String?
  billingAddress String?
  employees      Int?
  revenue        Float?
  assignedToId   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]
}

model Deal {
  id                String    @id @default(cuid())
  organizationId    String
  accountId         String?
  name              String
  value             Float?
  stage             String    @default("PROSPECTING")
  probability       Int       @default(10)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  source            String    @default("OTHER")
  assignedToId      String?
  notes             String?
  lostReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account      Account?      @relation(fields: [accountId], references: [id])
  contacts     DealContact[]
  activities   DealActivity[]
  quotes       Quote[]
}

model DealContact {
  dealId    String
  contactId String
  role      String?

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
}

model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  type      String
  title     String
  body      String?
  createdAt DateTime @default(now())
  createdBy String?

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CRM PHASE 1: ACTIVITIES (MEETINGS, CALLS)
// ─────────────────────────────────────────

model Meeting {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  description    String?
  location       String?
  startAt        DateTime
  endAt          DateTime?
  status         String    @default("SCHEDULED")
  leadId         String?
  dealId         String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     MeetingContact[]
}

model MeetingContact {
  meetingId String
  contactId String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([meetingId, contactId])
}

model CallLog {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  leadId         String?
  dealId         String?
  direction      String   @default("OUTBOUND")
  duration       Int?
  outcome        String   @default("CONNECTED")
  notes          String?
  calledAt       DateTime @default(now())
  createdBy      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id])
}

// ─────────────────────────────────────────
// CRM PHASE 2: PRODUCTS & QUOTES
// ─────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  category       String?
  unitPrice      Float    @default(0)
  currency       String   @default("USD")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteItems   QuoteItem[]
}

model Quote {
  id             String    @id @default(cuid())
  organizationId String
  dealId         String?
  contactId      String?
  number         String    @unique
  title          String
  status         String    @default("DRAFT")
  validUntil     DateTime?
  notes          String?
  subtotal       Float     @default(0)
  tax            Float     @default(0)
  total          Float     @default(0)
  currency       String    @default("USD")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deal         Deal?        @relation(fields: [dealId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id])
  items        QuoteItem[]
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────
// CRM PHASE 3: SUPPORT (CASES, DOCUMENTS)
// ─────────────────────────────────────────

model Case {
  id             String    @id @default(cuid())
  organizationId String
  contactId      String?
  accountId      String?
  subject        String
  description    String?
  status         String    @default("OPEN")
  priority       String    @default("MEDIUM")
  category       String?
  resolution     String?
  resolvedAt     DateTime?
  assignedToId   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comments     CaseComment[]
}

model CaseComment {
  id         String   @id @default(cuid())
  caseId     String
  body       String
  createdBy  String?
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model CrmDocument {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  fileType       String?
  url            String
  sizeBytes      Int?
  leadId         String?
  contactId      String?
  dealId         String?
  accountId      String?
  uploadedBy     String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
